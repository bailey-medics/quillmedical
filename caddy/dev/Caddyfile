:80 {
  encode zstd gzip

  # 1) API requests → backend
  @api path /api/*
  handle @api {
    reverse_proxy backend:8000
  }

  # 1b) EHRbase requests → ehrbase
  @ehrbase path /ehrbase/*
  handle @ehrbase {
    reverse_proxy ehrbase:8080
  }

  # 2) Ensure the PWA manifest is served with the correct MIME type
  @webmanifest path /*.webmanifest
  header @webmanifest Content-Type "application/manifest+json"
  header @webmanifest Cache-Control "no-cache"

  # 3) SPA served at /
  handle {
    reverse_proxy frontend:5173
  }
}
